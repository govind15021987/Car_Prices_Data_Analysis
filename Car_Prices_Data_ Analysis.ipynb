   "source": [
    "# Count null values\n",
    "null_count = car_df.isnull().sum()\n",
    "\n",
    "# Calculate percentage\n",
    "null_percentage = (null_count / len(car_df)) * 100\n",
    "\n",
    "# Create summary table\n",
    "null_summary = pd.DataFrame({\n",
    "    'Null Count': null_count,\n",
    "    'Null Percentage': round(null_percentage, 2)\n",
    "})\n",
    "\n",
    "# Display columns having nulls\n",
    "null_summary[null_summary['Null Count'] > 0].sort_values(\n",
    "    by='Null Percentage',\n",
    "    ascending=False\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
