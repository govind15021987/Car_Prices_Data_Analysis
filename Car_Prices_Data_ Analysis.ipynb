   "id": "835e0b73-fe74-4775-8af5-62e8f30cf53a",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Identify Numerical and Categorical Columns\n",
    "num_cols = car_df.select_dtypes(include=['int64', 'float64']).columns\n",
    "\n",
    "cat_cols = car_df.select_dtypes(include='object').columns"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 23,
   "id": "04f14c48-49c0-4417-a799-8b77c00b4de4",
   "metadata": {},
   "outputs": [],
   "source": [
    "# For numerical columns, using Median\n",
    "for col in num_cols:\n",
    "    missing_pct = (car_df[col].isnull().sum() / len(car_df)) * 100\n",
    "    \n",
    "    if missing_pct > 0 and missing_pct < 30:\n",
    "        car_df[col] = car_df[col].fillna(car_df[col].median())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 22,
   "id": "83a00ef1-28b1-41e2-9caa-6bfc0fa29c8d",
   "metadata": {},
   "outputs": [],
   "source": [
    "# For categorical columns, using Mode\n",
    "for col in cat_cols:\n",
    "    missing_pct = (car_df[col].isnull().sum() / len(car_df)) * 100\n",
    "    \n",
    "    if missing_pct > 0 and missing_pct < 30:\n",
    "        car_df[col] = car_df[col].fillna(car_df[col].mode()[0])"
   ]
  },
