   "source": [
    "#Highest odometer reading per year from highest to lowest order\n",
    "highest_odometer = (\n",
    "    car_df.groupby('year')['odometer']\n",
    "    .max()\n",
    "    .sort_values(ascending=False)\n",
    "    .reset_index()\n",
    ")\n",
    "\n",
    "highest_odometer.columns = ['Year', 'Highest Odometer']\n",
    "\n",
    "highest_odometer"
   ]
  },
